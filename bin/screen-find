#!/bin/bash

[ -z "$BASH_LIB" ] && BASH_LIB="$(dirname "$(dirname "$(readlink -f "$0")")")"
source "$BASH_LIB/lib/helper.inc.sh"

usage() {
    cat <<USAGE
$(bredn "Usage:") $(bwhiten "screen-find") [OPTIONS] [PID...]

Find which screen session/window contains a running process.

$(bredn "Modes:")
  PIDs as arguments:    screen-find 1234 5678
  PIDs from stdin:      pgrep claude | screen-find
  Keyword via pgrep:    screen-find -p claude

## OPTIONS
  -h, --help            Display help and exit
  -p, --pgrep PATTERN   Search for PIDs matching pattern via pgrep
## END OPTIONS
USAGE
}

RESULTS=()

screen_color_letter_to_name() {
    case "${1,,}" in
        k) echo "black" ;;
        r) echo "red" ;;
        g) echo "green" ;;
        y) echo "yellow" ;;
        b) echo "blue" ;;
        m) echo "magenta" ;;
        c) echo "cyan" ;;
        w) echo "white" ;;
        *) echo "" ;;
    esac
}

get_session_color_func() {
    local session="$1"
    local screen_pid="$2"
    local caption=""

    if [[ -n "$screen_pid" ]]; then
        local screen_cmd
        screen_cmd=$(ps -p "$screen_pid" -o command= 2>/dev/null)
        if [[ "$screen_cmd" =~ -c[[:space:]]+([^[:space:]]+) ]]; then
            local config_file="${BASH_REMATCH[1]}"
            config_file=$(eval echo "$config_file" 2>/dev/null)
            if [[ -f "$config_file" ]]; then
                caption=$(grep -h '^caption ' "$config_file" 2>/dev/null | tail -1)
            fi
        fi
    fi

    if [[ -z "$caption" ]]; then
        local rc_files=("$HOME/.screenrc.$session" "$HOME/.screenrc")
        for rc in "${rc_files[@]}"; do
            [[ -f "$rc" ]] || continue
            caption=$(grep -rh '^caption ' "$rc" $(grep -o 'source [^ ]*' "$rc" 2>/dev/null | sed 's/^source //' | while read -r f; do eval echo "$f" 2>/dev/null; done) 2>/dev/null | tail -1)
            [[ -n "$caption" ]] && break
        done
    fi

    if [[ -n "$caption" ]] && [[ "$caption" =~ %\{=[[:space:]]*([a-zA-Z])([a-zA-Z]) ]]; then
        local bg_letter="${BASH_REMATCH[1]}"
        local fg_letter="${BASH_REMATCH[2]}"
        local bg_name fg_name
        bg_name=$(screen_color_letter_to_name "$bg_letter")
        fg_name=$(screen_color_letter_to_name "$fg_letter")
        if [[ -n "$bg_name" && -n "$fg_name" ]]; then
            local func_name="b${bg_name}_${fg_name}"
            if declare -f "$func_name" > /dev/null 2>&1; then
                echo "$func_name"
                return
            fi
        fi
    fi
    echo "bblue_white"
}

screen_find_pid() {
    local TARGET_PID="$1"

    if ! ps -p "$TARGET_PID" > /dev/null 2>&1; then
        warn "PID $TARGET_PID not found"
        return 1
    fi

    local TARGET_TTY
    TARGET_TTY=$(ps -p "$TARGET_PID" -o tty= | tr -d ' ')
    if [[ -z "$TARGET_TTY" || "$TARGET_TTY" == "??" ]]; then
        warn "PID $TARGET_PID has no TTY (not running in a terminal)"
        return 1
    fi

    local CURRENT_PID="$TARGET_PID"
    local SCREEN_PID=""
    local SCREEN_NAME=""

    while [[ -n "$CURRENT_PID" && "$CURRENT_PID" != "1" ]]; do
        local PARENT_PID
        PARENT_PID=$(ps -p "$CURRENT_PID" -o ppid= | tr -d ' ')
        if [[ -z "$PARENT_PID" ]]; then
            break
        fi

        local PARENT_CMD
        PARENT_CMD=$(ps -p "$PARENT_PID" -o command= 2>/dev/null)
        if [[ "$PARENT_CMD" == *"/SCREEN "* || "$PARENT_CMD" == *"/screen "* ]]; then
            SCREEN_PID="$PARENT_PID"
            if [[ "$PARENT_CMD" =~ -S[[:space:]]+([^[:space:]]+) ]]; then
                SCREEN_NAME="${BASH_REMATCH[1]}"
            fi
            break
        fi

        CURRENT_PID="$PARENT_PID"
    done

    if [[ -z "$SCREEN_PID" ]]; then
        warn "PID $TARGET_PID is not running inside a screen session"
        return 1
    fi

    if [[ -z "$SCREEN_NAME" ]]; then
        SCREEN_NAME=$(screen -ls | grep "$SCREEN_PID" | sed -E 's/.*\.([^[:space:]]+).*/\1/' | head -1)
    fi

    local WINDOW_NUM=""
    local WINDOW_NAME=""
    local WINDOW_INDEX=0

    while IFS= read -r line; do
        local CHILD_TTY
        CHILD_TTY=$(echo "$line" | awk '{print $1}')
        local CHILD_TTY_CLEAN
        CHILD_TTY_CLEAN=$(echo "$CHILD_TTY" | sed 's/^ttys/s/')

        if [[ "$CHILD_TTY_CLEAN" == "$TARGET_TTY" || "$CHILD_TTY" == "$TARGET_TTY" ]]; then
            WINDOW_NUM="$WINDOW_INDEX"
            break
        fi
        ((WINDOW_INDEX++))
    done < <(ps -eo tty,pid,ppid --sort=pid 2>/dev/null | awk -v ppid="$SCREEN_PID" '$3 == ppid {print $1, $2}' || \
             ps -eo tty,pid,ppid | sort -k2 -n | awk -v ppid="$SCREEN_PID" '$3 == ppid {print $1, $2}')

    if [[ -z "$WINDOW_NUM" ]]; then
        WINDOW_INDEX=0
        while IFS= read -r line; do
            local CHILD_TTY
            CHILD_TTY=$(echo "$line" | awk '{print $1}')
            local CHILD_TTY_CLEAN
            CHILD_TTY_CLEAN=$(echo "$CHILD_TTY" | sed 's/^ttys/s/')

            if [[ "$CHILD_TTY_CLEAN" == "$TARGET_TTY" || "$CHILD_TTY" == "$TARGET_TTY" ]]; then
                WINDOW_NUM="$WINDOW_INDEX"
                break
            fi
            ((WINDOW_INDEX++))
        done < <(ps -o tty,pid -p $(pgrep -P "$SCREEN_PID" | tr '\n' ',')0 2>/dev/null | tail -n +2 | sort -k2 -n)
    fi

    if [[ -n "$SCREEN_NAME" && -n "$WINDOW_NUM" ]]; then
        WINDOW_NAME=$(screen -S "$SCREEN_NAME" -p "$WINDOW_NUM" -Q title 2>/dev/null)
    fi

    RESULTS+=("${SCREEN_NAME}|${WINDOW_NUM}|${WINDOW_NAME:--}|${TARGET_PID}|${SCREEN_PID}")
}

declare SESSION_COLORS

display_results() {
    if [[ ${#RESULTS[@]} -eq 0 ]]; then
        return
    fi

    local sessions=()
    local seen_sessions=""
    for entry in "${RESULTS[@]}"; do
        local session="${entry%%|*}"
        if [[ " $seen_sessions " != *" $session "* ]]; then
            sessions+=("$session")
            seen_sessions+=" $session"
        fi
    done

    for session in "${sessions[@]}"; do
        local color_func
        if [[ -n "${SESSION_COLORS[$session]:-}" ]]; then
            color_func="${SESSION_COLORS[$session]}"
        else
            local screen_pid=""
            for entry in "${RESULTS[@]}"; do
                if [[ "${entry%%|*}" == "$session" ]]; then
                    screen_pid=$(echo "$entry" | cut -d'|' -f5)
                    break
                fi
            done
            color_func=$(get_session_color_func "$session" "$screen_pid")
            SESSION_COLORS[$session]="$color_func"
        fi

        local separator
        separator=$(printf '%0.s-' {1..80})
        echo "$separator"
        echo "Session: $(bold "$session")"
        echo "$separator"

        local sorted_entries=()
        for entry in "${RESULTS[@]}"; do
            if [[ "${entry%%|*}" == "$session" ]]; then
                sorted_entries+=("$entry")
            fi
        done

        IFS=$'\n' sorted_entries=($(for e in "${sorted_entries[@]}"; do echo "$e"; done | sort -t'|' -k2 -n))
        unset IFS

        for entry in "${sorted_entries[@]}"; do
            local win_num win_name pid
            win_num=$(echo "$entry" | cut -d'|' -f2)
            win_name=$(echo "$entry" | cut -d'|' -f3)
            pid=$(echo "$entry" | cut -d'|' -f4)

            echo "  Window: $($color_func "$win_num $win_name")"
            echo "  Attach: screen -r $session -p $win_num"
            echo "  PID: $pid"
            echo ""
        done
    done
}

PIDS=()
PGREP_PATTERN=""

while [[ -n "$1" ]]; do
    case "$1" in
        ## OPTIONS
        -h|--help)
            usage
            exit 0
        ;;
        -p|--pgrep)
            PGREP_PATTERN="$2"
            shift
        ;;
        ## END OPTIONS
        *)
            PIDS+=("$1")
        ;;
    esac
    shift
done

if [[ -n "$PGREP_PATTERN" ]]; then
    while IFS= read -r pid; do
        [[ -n "$pid" ]] && PIDS+=("$pid")
    done < <(pgrep -f "$PGREP_PATTERN")

    if [[ ${#PIDS[@]} -eq 0 ]]; then
        quit "No process found matching '$PGREP_PATTERN'"
    fi
fi

if [[ ${#PIDS[@]} -eq 0 ]] && [[ ! -t 0 ]]; then
    while IFS= read -r pid; do
        pid=$(echo "$pid" | tr -d '[:space:]')
        [[ -n "$pid" ]] && PIDS+=("$pid")
    done
fi

if [[ ${#PIDS[@]} -eq 0 ]]; then
    usage
    exit 1
fi

FOUND=0
for pid in "${PIDS[@]}"; do
    screen_find_pid "$pid" && ((FOUND++))
done

[[ $FOUND -eq 0 ]] && exit 1

display_results
exit 0
